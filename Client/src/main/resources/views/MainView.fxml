<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="mainScroll" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.MainController">
    <content>
        <AnchorPane stylesheets="@style.css">
            <children>
                <ImageView fitHeight="${mainScroll.height}" fitWidth="${mainScroll.width}" mouseTransparent="true" preserveRatio="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <image>
                        <Image url="@../images/test_nen.png" />
                    </image>
                </ImageView>

                <VBox alignment="CENTER" layoutY="-2.0" prefWidth="1536.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="300.0">
                    <children>

                        <StackPane maxWidth="500.0" style="-fx-background-color: rgba(0, 0, 0, 0.5); -fx-background-radius: 30; -fx-padding: 50;">
                            <children>

                                <VBox fx:id="adminBox" alignment="CENTER" spacing="25.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleApproveAccounts" prefHeight="50.0" prefWidth="300.0" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 30; -fx-background-color: #28a745; -fx-font-size: 16; -fx-text-fill: white;" text="Kiểm duyệt tài khoản" />

                                        <Button mnemonicParsing="false" onAction="#handleManageUsers" prefHeight="50.0" prefWidth="300.0" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 30; -fx-background-color: #28a745; -fx-font-size: 16; -fx-text-fill: white;" text="Quản lý người dùng" />

                                        <Button mnemonicParsing="false" onAction="#handleManageAuctions" prefHeight="50.0" prefWidth="300.0" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 30; -fx-background-color: #28a745; -fx-font-size: 16; -fx-text-fill: white;" text="Quản lý phiên đấu giá" />

                                        <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="50.0" prefWidth="300.0" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 30; -fx-background-color: #dc3545; -fx-font-size: 16; -fx-text-fill: white;" text="Đăng xuất" />
                                    </children>
                                </VBox>

                                <VBox fx:id="userBox" alignment="CENTER" spacing="25.0" visible="false">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleMenuItem" prefHeight="50.0" prefWidth="300.0" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 30; -fx-background-color: #28a745; -fx-font-size: 16; -fx-text-fill: white;" text="Danh sách phòng" />

                                        <MenuButton fx:id="menuUser" accessibleText="người dùng" alignment="CENTER" mnemonicParsing="false" prefHeight="50.0" prefWidth="300.0" style="-fx-background-radius: 30; -fx-managed: true; -fx-font-weight: bold; -fx-background-color: #28a745; -fx-font-size: 16; -fx-text-fill: white; -fx-cursor: hand;" styleClass="user-menu-btn" text="Thông tin người dùng">
                                            <items>
                                                <MenuItem mnemonicParsing="false" onAction="#handleUserUi" text="👤 Hồ sơ cá nhân" />
                                                <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="➜] Đăng xuất" />
                                            </items>
                                        </MenuButton>

                                        <Button mnemonicParsing="false" onAction="#handleUpgrade" prefHeight="50.0" prefWidth="300.0" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 30; -fx-background-color: #28a745; -fx-font-size: 16; -fx-text-fill: white;" text="Nâng cấp lên Seller" />
                                    </children>
                                </VBox>

                            </children>
                        </StackPane>

                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </content>
</ScrollPane>
