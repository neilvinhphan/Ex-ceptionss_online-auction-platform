<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="768.0" prefWidth="1200.0" style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.MainController">
    <content>
        <VBox minHeight="760.0" style="-fx-background-color: #F3F5F8;">
            <children>

                <BorderPane VBox.vgrow="ALWAYS">

                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                            </BorderPane.margin>
                            <fx:include source="MenuView.fxml" />
                        </VBox>
                    </top>

                    <center>
                        <VBox spacing="40.0" BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="40.0" left="75.0" right="75.0" />
                            </BorderPane.margin>
                            <children>

                                <HBox fx:id="upgradeBanner" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                                    <children>
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label text="Trở thành Người Bán (Seller) ngay hôm nay!" textFill="#333333">
                                                    <font>
                                                        <Font name="System Bold" size="24.0" />
                                                    </font>
                                                </Label>
                                                <Label text="Mở khóa tính năng tạo phòng đấu giá, đăng bán tài sản và tiếp cận hàng ngàn người mua." textFill="#666666">
                                                    <font>
                                                        <Font size="15.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleUpgrade" style="-fx-background-color: #ffc107; -fx-text-fill: #333333; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 25; -fx-cursor: hand; -fx-font-size: 16; -fx-effect: dropshadow(gaussian, rgba(255,193,7,0.4), 10, 0, 0, 4);" text="🚀 Nâng cấp Seller" />
                                    </children>
                                </HBox>

                                <VBox spacing="15.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="🌟 Các cuộc đấu giá được đề cử" textFill="#fca311">
                                                <font><Font name="System Bold" size="22.0" /></font>
                                            </Label>
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button text="Tìm hiểu thêm về Quảng cáo" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-weight: bold; -fx-cursor: hand;" />
                                        </HBox>

                                        <FlowPane fx:id="promotedAuctionsContainer" hgap="20.0" prefWrapLength="1050.0" style="-fx-padding: 5 5 15 5;" vgap="20.0">
                                        </FlowPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </center>

                    <bottom>
                        <fx:include source="FooterView.fxml" BorderPane.alignment="CENTER" />
                    </bottom>

                </BorderPane>
            </children>
        </VBox>
    </content>
</ScrollPane>