<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="768.0" prefWidth="1200.0"
            style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8; -fx-padding: 0; -fx-background-insets: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"
            stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controllers.ManageUserController">
   <content>
        <VBox minHeight="760.0" style="-fx-background-color: #F3F5F8;">
            <children>

                <BorderPane VBox.vgrow="ALWAYS">

                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                            </BorderPane.margin>
                            <fx:include source="AdminMenuView.fxml" />
                        </VBox>
                    </top>

                    <left>
                        <VBox BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" left="40.0" right="20.0" />
                            </BorderPane.margin>
                            <fx:include source="AdminSideBarView.fxml" />
                        </VBox>
                    </left>

                    <center>
                        <VBox spacing="20.0" BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" right="40.0" />
                            </BorderPane.margin>
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox>
                                            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="Quản Lý Người Dùng">
                                                <font>
                                                    <Font size="24.0" />
                                                </font>
                                            </Label>
                                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" text="Theo dõi, tìm kiếm và xử lý vi phạm tài khoản thành viên." />
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                                    <children>
                                        <TextField fx:id="searchField" prefHeight="38.0" prefWidth="300.0" promptText="🔍 Tìm username, email, SĐT..." style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: #f8fafc; -fx-padding: 5 10;" />

                                        <Button mnemonicParsing="false" onAction="#handleSearch" prefHeight="38.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20;" text="Tìm kiếm" />

                                        <Region HBox.hgrow="ALWAYS" />

                                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="38.0" style="-fx-background-color: #ecfdf5; -fx-text-fill: #059669; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15;" text="🔄 Làm mới" />
                                        <Button mnemonicParsing="false" onAction="#handleUnbanUser" prefHeight="38.0" style="-fx-background-color: #f0fdf4; -fx-text-fill: #16a34a; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15; -fx-border-color: #bbf7d0; -fx-border-radius: 8;" text="✅ Mở khóa" />
                                        <Button mnemonicParsing="false" onAction="#handleBanUser" prefHeight="38.0" style="-fx-background-color: #fef2f2; -fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15; -fx-border-color: #fca5a5; -fx-border-radius: 8;" text="🚫 Khóa (Ban)" />
                                    </children>
                                </HBox>

                                <TableView fx:id="userTable" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colUsername" prefWidth="150.0" text="UserName" />
                                        <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email" />
                                        <TableColumn fx:id="colPhone" prefWidth="130.0" text="Số điện thoại" />
                                        <TableColumn fx:id="colRole" prefWidth="100.0" text="Vai trò" />
                                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Trạng thái" />
                                        <TableColumn fx:id="colBalance" prefWidth="150.0" text="Số dư" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                            </children>
                        </VBox>
                    </center>
                </BorderPane>

            </children>
        </VBox>
    </content>
</ScrollPane>
