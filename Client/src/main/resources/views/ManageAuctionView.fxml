<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="768.0" prefWidth="1200.0" style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8; -fx-padding: 0; -fx-background-insets: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.ManageAuctionController">
   <content>
        <VBox minHeight="760.0" style="-fx-background-color: #F3F5F8;">
            <children>

                <BorderPane VBox.vgrow="ALWAYS">

                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                            </BorderPane.margin>
                            <fx:include source="AdminMenuView.fxml" />
                        </VBox>
                    </top>

                    <left>
                        <VBox BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" left="40.0" right="20.0" />
                            </BorderPane.margin>
                            <fx:include source="AdminSideBarView.fxml" />
                        </VBox>
                    </left>

                    <center>
                        <VBox spacing="20.0" BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" right="40.0" />
                            </BorderPane.margin>
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox>
                                            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 26;" text="Quản Lý Phiên Đấu Giá" />

                                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14;" text="Giám sát và kiểm soát toàn bộ các cuộc đấu giá trên nền tảng." />
                                        </VBox>

                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                                    <children>
                                        <TextField fx:id="searchField" prefHeight="38.0" prefWidth="280.0" promptText="🔍 Tìm theo ID, Tên sản phẩm..." style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: #f8fafc; -fx-padding: 5 10;" />

                                        <Button mnemonicParsing="false" onAction="#handleSearch" prefHeight="38.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20;" text="Tìm kiếm" />

                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="38.0" style="-fx-background-color: #ecfdf5; -fx-text-fill: #059669; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15;" text="🔄 Làm mới" />
                                        <Button mnemonicParsing="false" onAction="#handleCancelAuction" prefHeight="38.0" style="-fx-background-color: #fef2f2; -fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15; -fx-border-color: #fca5a5; -fx-border-radius: 8;" text="🚨 Hủy phiên khẩn cấp" />
                                    </children>
                                </HBox>

                                <TableView fx:id="auctionTable" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="70.0" text="ID Phiên" />
                                        <TableColumn fx:id="colItemName" prefWidth="250.0" text="Tên sản phẩm" />
                                        <TableColumn fx:id="colSeller" prefWidth="150.0" text="Người bán" />
                                        <TableColumn fx:id="colStartTime" prefWidth="150.0" text="Giờ bắt đầu" />
                                        <TableColumn fx:id="colCurrentPrice" prefWidth="150.0" text="Giá hiện tại" />
                                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="Trạng thái" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                            </children>
                        </VBox>
                    </center>
                </BorderPane>

            </children>
        </VBox>
    </content>
</ScrollPane>
