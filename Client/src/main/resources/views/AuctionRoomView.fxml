<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.AuctionRoomController">
    <content>
        <BorderPane prefWidth="1200.0" style="-fx-background-color: #F8F9FA;">

            <top>
                <HBox alignment="CENTER" spacing="20.0" style="-fx-background-radius: 40; -fx-background-color: white; -fx-padding: 10 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <BorderPane.margin>
                        <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                    </BorderPane.margin>
                    <children>
                        <Button onAction="#handleMain" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-text-fill: #28a745; -fx-cursor: hand;" text="Trang chủ" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="PHÒNG ĐẤU GIÁ TRỰC TIẾP" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleExitRoom" style="-fx-background-color: #ff4d4d; -fx-text-fill: white; -fx-background-radius: 20; -fx-cursor: hand;" text="Rời phòng" />
                    </children>
                </HBox>
            </top>

            <center>
                <HBox alignment="TOP_CENTER" spacing="30.0" style="-fx-padding: 20;">
                    <VBox maxWidth="700.0" spacing="20.0">
                        <StackPane prefHeight="400.0" style="-fx-background-color: #ECEFF1; -fx-background-radius: 10;">
                            <Label style="-fx-text-fill: #999; -fx-font-weight: bold;" text="HÌNH ẢNH TÀI SẢN ĐANG ĐẤU GIÁ" />
                        </StackPane>

                        <Label style="-fx-font-size: 22; -fx-font-weight: bold;" text="Tên tài sản: Biệt thự nghỉ dưỡng cao cấp tại Đà Lạt" wrapText="true" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #fff0f0; -fx-padding: 15; -fx-background-radius: 5; -fx-border-color: #ffcccc; -fx-border-radius: 5;">
                            <Label style="-fx-font-size: 20;" text="⏱" />
                            <Label style="-fx-font-size: 16; -fx-text-fill: #555;" text="Thời gian còn lại:" />
                            <Label fx:id="lblTimer" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="02:30:15" />
                        </HBox>

                        <TextArea editable="false" prefHeight="150.0" style="-fx-border-color: #DDD;" text="Thông tin chi tiết:&#10;Diện tích: 200m2&#10;Tình trạng: Mới 100%&#10;Mô tả: Biệt thự có view nhìn ra thung lũng, đầy đủ nội thất sang trọng..." />
                    </VBox>

                    <VBox prefWidth="350.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                        <Label style="-fx-text-fill: #666;" text="Giá hiện tại" />
                        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #28a745;" text="5.500.000.000 đ" />

                        <Separator />

                        <Label text="Nhập giá đấu của bạn:" />
                        <TextField fx:id="tfBidAmount" promptText="Nhập số tiền..." style="-fx-padding: 10;" />
                        <Button maxWidth="Infinity" onAction="#handlePlaceBid" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-cursor: hand;" text="ĐẶT GIÁ NGAY" />

                        <Label style="-fx-font-weight: bold;" text="Lịch sử đấu giá:" />
                        <ListView fx:id="lvBidHistory" prefHeight="200.0" style="-fx-border-color: #DDD;" />
                    </VBox>
                </HBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
