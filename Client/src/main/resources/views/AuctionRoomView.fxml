<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.auction.AuctionRoomController">

    <content>
        <BorderPane style="-fx-background-color:#f3f4f6;">

            <top>
                <HBox alignment="CENTER" spacing="20" style="-fx-background-color:white; -fx-padding:12 30; -fx-background-radius:0 0 20 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                    <Button onAction="#handleBackToCatalog" style="-fx-background-color:#f8f9fa; -fx-border-color:#ced4da; -fx-border-radius:6; -fx-font-weight:bold; -fx-cursor:hand;" text="← Thoát phòng" />
                    <Region HBox.hgrow="ALWAYS" />
                    <VBox alignment="CENTER">
                        <Label alignment="CENTER" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="SÀN ĐẤU GIÁ THỜI GIAN THỰC" />
                        <HBox alignment="CENTER" spacing="8">
                            <Label style="-fx-font-size:12; -fx-text-fill:#28a745; -fx-font-weight:bold;" text="● Kết nối trực tuyến ổn định" />
                            <Label fx:id="lblOnlineCount" style="-fx-font-size:12; -fx-text-fill:#0984e3; -fx-font-weight:bold;" text="| 👥 Đang xem: null" />
                        </HBox>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
            </top>

            <center>
                <HBox spacing="25" style="-fx-padding:25;">

                    <VBox minWidth="480" prefWidth="520" spacing="15" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                        <StackPane prefHeight="320" style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-padding: 5;">
                            <children>
                                <ImageView fx:id="ivItemImage" fitHeight="310.0" fitWidth="480.0" pickOnBounds="true" preserveRatio="true" />
                            </children>
                        </StackPane>

                        <VBox spacing="4">
                            <Label style="-fx-font-size:13; -fx-text-fill:#747d8c; -fx-font-weight:bold;" text="TÊN SẢN PHẨM SÀN ĐẤU" />
                            <Label fx:id="lblItemName" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#0984e3;" text="--" wrapText="true" />
                        </VBox>

                        <VBox spacing="5" VBox.vgrow="ALWAYS">
                            <Label style="-fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="Mô tả:" />
                            <TextArea fx:id="taDescription" editable="false" minHeight="90" prefHeight="110" style="-fx-background-radius:10; -fx-font-size:13;" wrapText="true" />
                        </VBox>

                        <Separator opacity="0.0" />
                        <StackPane>
                        <VBox fx:id="vboxBidderControls" spacing="12" style="-fx-padding:15; -fx-background-color:#f8f9fa; -fx-background-radius:12; -fx-border-color:#dee2e6; -fx-border-radius:12;">
                            <Label style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="🎮 KHU VỰC ĐIỀU KHIỂN ĐẶT THẦU" />
                            <HBox spacing="8">
                                <Button maxWidth="Infinity" onAction="#handleQuickBidStep" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" text="+ Bước giá" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#handleQuickBid50" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" text="+ 50K" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#handleQuickBid100" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" text="+ 100K" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#handleQuickBid500" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" text="+ 500K" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <TextField fx:id="tfBidAmount" prefHeight="38" promptText="Nhập số tiền muốn đặt (VND)..." style="-fx-font-size:14; -fx-background-radius:6;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnPlaceBid" onAction="#handlePlaceBid" prefHeight="38" prefWidth="140" style="-fx-background-color:#28a745; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13; -fx-background-radius:6; -fx-cursor:hand;" text="GỬI GIÁ ĐẤU" />
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <TextField fx:id="tfMaxBid" prefHeight="38" promptText="Cài hạn mức trần Auto..." style="-fx-font-size:14; -fx-background-radius:6;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnToggleAutoBid" onAction="#handleToggleAutoBid" prefHeight="38" prefWidth="140" style="-fx-background-color:#ff9800; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13; -fx-background-radius:6; -fx-cursor:hand;" text="BẬT AUTOBID" />
                            </HBox>

                            <Label fx:id="lblBidError" style="-fx-text-fill:red; -fx-font-size:12; -fx-font-weight:bold;" text="" wrapText="true" />
                        </VBox>
                        <VBox fx:id="vboxSellerControls" managed="false" spacing="12" style="-fx-padding:15; -fx-background-color:#e8f5e9; -fx-background-radius:12; -fx-border-color:#c8e6c9; -fx-border-radius:12;" visible="false">
                            <Label style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#2e7d32;" text="📊 THEO DÕI TRẠNG THÁI TÀI SẢN CỦA BẠN" />

                            <Label style="-fx-text-fill:#37474f; -fx-font-size:13;" text="Hệ thống đang tự động điều phối phiên đấu giá. Chúc tài sản của bạn đạt được mức giá tốt nhất!" wrapText="true" />


                        </VBox>


                        <VBox fx:id="vboxAdminControls" managed="false" spacing="12" style="-fx-padding:15; -fx-background-color:#ffebee; -fx-background-radius:12; -fx-border-color:#ffcdd2; -fx-border-radius:12;" visible="false">
                            <Label style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#c62828;" text="⚙ KHU VỰC ĐIỀU KHIỂN QUẢN TRỊ" />

                            <HBox spacing="10">
                                  <Button maxWidth="Infinity" onAction="#handleForceCancel" prefHeight="38" style="-fx-background-color:#d32f2f; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:6; -fx-cursor:hand;" text="Hủy Lập Tức (Vi phạm)" HBox.hgrow="ALWAYS" />

                            </HBox>

                            <Label style="-fx-text-fill:#d32f2f; -fx-font-size:12; -fx-font-weight:bold;" text="⚠ Chú ý: Hành động của Admin sẽ can thiệp trực tiếp vào kết quả giao dịch." wrapText="true" />
                        </VBox>
                        </StackPane>
                    </VBox>

                    <VBox spacing="20" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">

                        <HBox alignment="CENTER" spacing="15">
                            <VBox alignment="CENTER" spacing="6" style="-fx-background-color:#fff5f5; -fx-padding:12 20; -fx-background-radius:12; -fx-border-color:#ffc9c9; -fx-border-radius:12;" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER" spacing="6">
                                    <Label style="-fx-text-fill:#e74c3c; -fx-font-weight:bold; -fx-font-size:12;" text="⏱ THỜI GIAN:" />
                                    <Label fx:id="lblStatus" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#e74c3c;" text="OPEN" />
                                </HBox>
                                <Label fx:id="lblTimer" style="-fx-font-size:26; -fx-font-weight:bold; -fx-text-fill:#c0392b;" text="00:00:00" />
                            </VBox>
                            <StackPane HBox.hgrow="ALWAYS">
                            <VBox fx:id="vboxPriceBox" alignment="CENTER" spacing="4" style="-fx-background-color:#ebfbee; -fx-padding:12 20; -fx-background-radius:12; -fx-border-color:#b2f2bb; -fx-border-radius:12;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill:#2f9e44; -fx-font-weight:bold; -fx-font-size:12;" text="MỨC GIÁ CAO NHẤT HIỆN TẠI" />
                                <Label fx:id="lblCurrentPrice" style="-fx-font-size:26; -fx-text-fill:#2b8a3e; -fx-font-weight:bold;" text="0 đ" />
                            </VBox>
                                <VBox fx:id="vboxWinnerBox" alignment="CENTER" managed="false" spacing="4" style="-fx-background-color:#fff8e1; -fx-padding:12 20; -fx-background-radius:12; -fx-border-color:#ffe082; -fx-border-radius:12;" visible="false">
                                    <Label style="-fx-text-fill:#f57f17; -fx-font-weight:bold; -fx-font-size:12;" text="🏆 NGƯỜI CHIẾN THẮNG" />
                                    <Label fx:id="lblWinner" style="-fx-font-size:26; -fx-text-fill:#f57c00; -fx-font-weight:bold;" text="--" />
                                </VBox>
                            </StackPane>
                        </HBox>

                        <HBox alignment="CENTER" style="-fx-background-color:#f1f3f5; -fx-padding:10 20; -fx-background-radius:8;">
                            <Label style="-fx-text-fill:#495057;" text="Bước giá tối thiểu: " />
                            <Label fx:id="lblBid" style="-fx-font-weight:bold; -fx-text-fill:#212529;" text=".... đ" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label style="-fx-text-fill:#495057;" text="🏆 Đang dẫn đầu: " />
                            <Label fx:id="lblHighestBidder" style="-fx-font-weight:bold; -fx-text-fill:#0984e3;" text="Chưa có" />
                        </HBox>

                        <VBox spacing="5" VBox.vgrow="ALWAYS">
                            <Label style="-fx-font-weight:bold; -fx-text-fill:#2c3e50; -fx-font-size:14;" text="📈 Đồ thị lịch sử biến động giá:" />
                            <LineChart fx:id="lineChart" createSymbols="true" prefHeight="200" VBox.vgrow="ALWAYS">
                                <xAxis>
                                    <NumberAxis label="Lượt thầu (Lần)" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Giá tiền (VND)" />
                                </yAxis>
                            </LineChart>
                        </VBox>

                        <VBox spacing="5">
                            <Label style="-fx-font-weight:bold; -fx-text-fill:#2c3e50; -fx-font-size:14;" text="📜 Nhật ký đặt giá phòng:" />
                            <ListView fx:id="lvBidHistory" prefHeight="130" style="-fx-background-radius:8; -fx-font-size:13;" />
                        </VBox>

                        <Separator />

                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:5 0;">
                            <Region HBox.hgrow="ALWAYS" />
                            <VBox fx:id="vboxCheckoutSection" alignment="CENTER_RIGHT" prefWidth="200">
                                <Button fx:id="btnCheckout" managed="false" maxWidth="Infinity" onAction="#handleCheckout" prefHeight="38" style="-fx-background-color:#ff9f43; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13; -fx-background-radius:6; -fx-cursor:hand;" text="THANH TOÁN NGAY" visible="false" />
                                <Label fx:id="lblPostAuctionStatus" alignment="CENTER" managed="false" style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#e74c3c;" text="Giao dịch quá hạn bị hủy!" visible="false" wrapText="true" />
                            </VBox>
                        </HBox>

                    </VBox>

                </HBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
