<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controllers.AuctionRoomController">

    <content>
        <BorderPane style="-fx-background-color:#f3f4f6;">

            <top>
                <HBox alignment="CENTER" spacing="20"
                      style="-fx-background-color:white; -fx-padding:12 30; -fx-background-radius:0 0 20 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                    <Button onAction="#handleBackToCatalog"
                            style="-fx-background-color:#f8f9fa; -fx-border-color:#ced4da; -fx-border-radius:6; -fx-font-weight:bold; -fx-cursor:hand;"
                            text="← Thoát phòng"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox alignment="CENTER">
                        <Label style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"
                               text="SÀN ĐẤU GIÁ THỜI GIAN THỰC"/>
                        <HBox spacing="8" alignment="CENTER">
                            <Label style="-fx-font-size:12; -fx-text-fill:#28a745; -fx-font-weight:bold;"
                                   text="● Kết nối trực tuyến ổn định"/>
                            <Label fx:id="lblOnlineCount" style="-fx-font-size:12; -fx-text-fill:#0984e3; -fx-font-weight:bold;"
                                   text="| 👥 Đang xem: 1 người"/>
                        </HBox>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#handleMain"
                            style="-fx-background-color:#e8f5e9; -fx-text-fill:#28a745; -fx-font-weight:bold; -fx-cursor:hand;"
                            text="Trang chủ"/>
                </HBox>
            </top>

            <center>
                <HBox spacing="25" style="-fx-padding:25;">

                    <VBox spacing="15" prefWidth="520" minWidth="480"
                          style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                        <StackPane prefHeight="320" style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-padding: 5;">
                            <children>
                                <ImageView fx:id="ivItemImage" fitHeight="310.0" fitWidth="480.0"
                                           pickOnBounds="true" preserveRatio="true"/>
                            </children>
                        </StackPane>

                        <VBox spacing="4">
                            <Label style="-fx-font-size:13; -fx-text-fill:#747d8c; -fx-font-weight:bold;" text="TÊN SẢN PHẨM SÀN ĐẤU" />
                            <Label fx:id="lblItemName" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#0984e3;" text="--" wrapText="true" />
                        </VBox>

                        <VBox spacing="5" VBox.vgrow="ALWAYS">
                            <Label style="-fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="Mô tả chi tiết tài sản:"/>
                            <TextArea fx:id="taDescription" editable="false" prefHeight="110" minHeight="90"
                                      style="-fx-background-radius:10; -fx-font-size:13;" wrapText="true"/>
                        </VBox>

                        <Separator/>

                        <VBox spacing="12" style="-fx-padding:15; -fx-background-color:#f8f9fa; -fx-background-radius:12; -fx-border-color:#dee2e6; -fx-border-radius:12;">
                            <Label style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="🎮 KHU VỰC ĐIỀU KHIỂN ĐẶT THẦU" />

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="tfBidAmount" prefHeight="38" promptText="Nhập số tiền muốn đặt (VND)..."
                                           style="-fx-font-size:14; -fx-background-radius:6;" HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnPlaceBid" onAction="#handlePlaceBid" prefHeight="38" prefWidth="140"
                                        style="-fx-background-color:#28a745; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13; -fx-background-radius:6; -fx-cursor:hand;"
                                        text="GỬI GIÁ ĐẤU"/>
                            </HBox>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="tfMaxBid" prefHeight="38" promptText="Cài hạn mức trần Auto..."
                                           style="-fx-font-size:14; -fx-background-radius:6;" HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnToggleAutoBid" onAction="#handleToggleAutoBid" prefHeight="38" prefWidth="140"
                                        style="-fx-background-color:#ff9800; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13; -fx-background-radius:6; -fx-cursor:hand;"
                                        text="BẬT AUTOBID"/>
                            </HBox>

                            <Label fx:id="lblBidError" style="-fx-text-fill:red; -fx-font-size:12; -fx-font-weight:bold;" text="" wrapText="true"/>
                        </VBox>
                    </VBox>

                    <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                        <HBox spacing="15" alignment="CENTER">
                            <VBox spacing="6" style="-fx-background-color:#fff5f5; -fx-padding:12 20; -fx-background-radius:12; -fx-border-color:#ffc9c9; -fx-border-radius:12;" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <HBox spacing="6" alignment="CENTER">
                                    <Label style="-fx-text-fill:#e74c3c; -fx-font-weight:bold; -fx-font-size:12;" text="⏱ THỜI GIAN:" />
                                    <Label fx:id="lblStatus" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#e74c3c;" text="OPEN" />
                                </HBox>
                                <Label fx:id="lblTimer" style="-fx-font-size:26; -fx-font-weight:bold; -fx-text-fill:#c0392b;" text="00:00:00"/>
                            </VBox>

                            <VBox spacing="4" style="-fx-background-color:#ebfbee; -fx-padding:12 20; -fx-background-radius:12; -fx-border-color:#b2f2bb; -fx-border-radius:12;" HBox.hgrow="ALWAYS" alignment="CENTER">
                                <Label style="-fx-text-fill:#2f9e44; -fx-font-weight:bold; -fx-font-size:12;" text="MỨC GIÁ CAO NHẤT HIỆN TẠI" />
                                <Label fx:id="lblCurrentPrice" style="-fx-font-size:26; -fx-text-fill:#2b8a3e; -fx-font-weight:bold;" text="0 đ"/>
                            </VBox>
                        </HBox>

                        <HBox style="-fx-background-color:#f1f3f5; -fx-padding:10 20; -fx-background-radius:8;" alignment="CENTER">
                            <Label style="-fx-text-fill:#495057;" text="Bước giá tối thiểu: " />
                            <Label fx:id="lblBid" style="-fx-font-weight:bold; -fx-text-fill:#212529;" text=".... đ"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label style="-fx-text-fill:#495057;" text="🏆 Đang dẫn đầu: " />
                            <Label fx:id="lblHighestBidder" style="-fx-font-weight:bold; -fx-text-fill:#0984e3;" text="Chưa có"/>
                        </HBox>

                        <VBox spacing="5" VBox.vgrow="ALWAYS">
                            <Label style="-fx-font-weight:bold; -fx-text-fill:#2c3e50; -fx-font-size:14;" text="📈 Đồ thị lịch sử biến động giá:"/>
                            <LineChart fx:id="lineChart" createSymbols="true" prefHeight="200" VBox.vgrow="ALWAYS">
                                <xAxis>
                                    <NumberAxis label="Lượt thầu (Lần)" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Giá tiền (VND)" />
                                </yAxis>
                            </LineChart>
                        </VBox>

                        <VBox spacing="5">
                            <Label style="-fx-font-weight:bold; -fx-text-fill:#2c3e50; -fx-font-size:14;" text="📜 Nhật ký đặt giá phòng:"/>
                            <ListView fx:id="lvBidHistory" prefHeight="130" style="-fx-background-radius:8; -fx-font-size:13;"/>
                        </VBox>

                        <Separator/>

                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:5 0;">
                            <Label style="-fx-font-size:14; -fx-text-fill:#495057;" text="Người chiến thắng chung cuộc:"/>
                            <Label fx:id="lblWinner" style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#228be6;" text="--"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <VBox fx:id="vboxCheckoutSection" alignment="CENTER_RIGHT" prefWidth="200">
                                <Button fx:id="btnCheckout" managed="false" maxWidth="Infinity"
                                        onAction="#handleCheckout" prefHeight="38"
                                        style="-fx-background-color:#ff9f43; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13; -fx-background-radius:6; -fx-cursor:hand;"
                                        text="THANH TOÁN NGAY" visible="false"/>
                                <Label fx:id="lblPostAuctionStatus" alignment="CENTER" managed="false"
                                       style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#e74c3c;"
                                       text="Giao dịch quá hạn bị hủy!" visible="false" wrapText="true"/>
                            </VBox>
                        </HBox>

                    </VBox>

                </HBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>