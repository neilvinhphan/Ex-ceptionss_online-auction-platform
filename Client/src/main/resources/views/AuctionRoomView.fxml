<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="850.0" prefWidth="1300.0" style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8; -fx-padding: 0; -fx-background-insets: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.AuctionRoomController">

    <content>
        <BorderPane style="-fx-background-color:#f3f4f6;">

            <top>
                <HBox alignment="CENTER" spacing="20" style="-fx-background-color:white; -fx-padding:15 30; -fx-background-radius:0 0 20 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 5);">
                    <Button onAction="#handleBackToCatalog" style="-fx-background-color:#f8f9fa; -fx-border-color:#ced4da; -fx-border-radius:5; -fx-cursor: hand;" text="← Thoát phòng" />
                    <Region HBox.hgrow="ALWAYS" />
                    <VBox alignment="CENTER" spacing="2">
                        <Label style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" text="Phòng Đấu Giá Trực Tuyến" />
                        <HBox alignment="CENTER" spacing="5">
                            <Label style="-fx-font-size:12; -fx-text-fill:#e74c3c; -fx-font-weight:bold;" text="● TRỰC TIẾP" />
                            <Label fx:id="lblLiveViewersHeader" style="-fx-font-size:12; -fx-text-fill:#7f8c8d;" text="- 👁️ 0 người đang xem" />
                        </HBox>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
            </top>

            <center>
                <HBox spacing="20" style="-fx-padding:20;">

                    <VBox spacing="15" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">

                        <StackPane prefHeight="300" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-border-color: #e9ecef; -fx-border-radius: 10;">
                            <children>
                                <ImageView fx:id="ivItemImage" fitHeight="280.0" fitWidth="500.0" pickOnBounds="true" preserveRatio="true" />

                                <HBox alignment="BOTTOM_RIGHT" spacing="10" style="-fx-padding: 10;" StackPane.alignment="BOTTOM_RIGHT">
                                    <Button onAction="#handleReactHeart" style="-fx-background-color: rgba(255,255,255,0.8); -fx-background-radius: 20; -fx-cursor: hand;" text="❤" />
                                    <Button onAction="#handleReactFire" style="-fx-background-color: rgba(255,255,255,0.8); -fx-background-radius: 20; -fx-cursor: hand;" text="🔥" />
                                    <Button onAction="#handleReactClap" style="-fx-background-color: rgba(255,255,255,0.8); -fx-background-radius: 20; -fx-cursor: hand;" text="👏" />
                                </HBox>
                            </children>
                        </StackPane>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#2d3436;" text="Tài sản:" />
                            <Label fx:id="lblItemName" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#0984e3;" text="[Tên sản phẩm]" />
                        </HBox>

                        <HBox spacing="15">
                            <VBox spacing="5" style="-fx-background-color:#fff0f0; -fx-padding:15; -fx-background-radius:10; -fx-border-color: #ffcccc; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-text-fill:#c0392b; -fx-font-weight: bold;" text="⏱ Thời gian còn lại" />
                                <Label fx:id="lblTimer" style="-fx-font-size:28; -fx-font-weight:bold; -fx-text-fill:#e74c3c;" text="00:00:00" />
                                <Label style="-fx-font-size:11; -fx-text-fill:#d35400;" text="*Tự động +2 phút nếu có người trả giá ở phút cuối" wrapText="true" />
                            </VBox>

                            <VBox spacing="5" style="-fx-background-color:#f1f3f5; -fx-padding:15; -fx-background-radius:10;" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #495057;" text="📈 Bước giá tối thiểu" />
                                <Label fx:id="lblBid" style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#2b8a3e;" text="...." />
                                <HBox spacing="5">
                                    <Label style="-fx-font-size:12; -fx-text-fill:#868e96;" text="Trạng thái:" />
                                    <Label fx:id="lblStatus" style="-fx-font-size:12; -fx-text-fill:#e67e22; -fx-font-weight:bold;" text="....." />
                                </HBox>
                            </VBox>
                        </HBox>

                        <Label style="-fx-font-weight:bold; -fx-font-size:14;" text="Mô tả chi tiết:" />
                        <TextArea fx:id="taDescription" editable="false" prefHeight="200" style="-fx-background-radius:10; -fx-control-inner-background: #fdfdfd;" wrapText="true" />
                    </VBox>

                    <VBox prefWidth="420" spacing="15" style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

                        <VBox alignment="CENTER" spacing="5" style="-fx-background-color:#ebfbee; -fx-padding:20; -fx-background-radius:10; -fx-border-color:#40c057; -fx-border-radius:10; -fx-border-width: 2;">
                            <Label fx:id="lblPriceTitle" style="-fx-text-fill:#2b8a3e; -fx-font-weight: bold;" text="MỨC GIÁ CAO NHẤT HIỆN TẠI" />

                            <Label fx:id="lblCurrentPrice" style="-fx-font-size:36; -fx-text-fill:#28a745; -fx-font-weight:bold;" text="0" />

                            <HBox alignment="CENTER" spacing="5" style="-fx-padding: 5 0 0 0;">
                                <Label fx:id="lblLeaderTitle" text="👑 Người dẫn đầu:" textFill="#555" />
                                <Label fx:id="lblHighestBidder" style="-fx-font-weight:bold; -fx-text-fill: #000;" text="Chưa có" />
                            </HBox>
                        </VBox>

                        <StackPane fx:id="spRolePanels">

                            <VBox fx:id="panelBidder" spacing="10" style="-fx-padding:15; -fx-background-color:#f8f9fa; -fx-background-radius:10; -fx-border-color:#dee2e6; -fx-border-radius:10;">
                                <Label style="-fx-font-weight:bold;" text="Nhập giá muốn đặt (VNĐ):" />

                                <HBox spacing="10">
                                    <Button maxWidth="Infinity" onAction="#handleQuickBidStep" style="-fx-background-color:#e7f5ff; -fx-text-fill:#1864ab; -fx-cursor: hand;" text="+ 1 Bước giá" HBox.hgrow="ALWAYS" />
                                    <Button maxWidth="Infinity" onAction="#handleQuickBid50k" style="-fx-background-color:#e7f5ff; -fx-text-fill:#1864ab; -fx-cursor: hand;" text="+ 50.000" HBox.hgrow="ALWAYS" />
                                    <Button maxWidth="Infinity" onAction="#handleQuickBid100k" style="-fx-background-color:#e7f5ff; -fx-text-fill:#1864ab; -fx-cursor: hand;" text="+ 100.000" HBox.hgrow="ALWAYS" />
                                </HBox>

                                <TextField fx:id="tfBidAmount" prefHeight="45" promptText="Nhập số tiền..." style="-fx-font-size:18; -fx-font-weight: bold;" />

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <CheckBox fx:id="cbAutoBid" style="-fx-text-fill: #495057;" text="🤖 Đấu giá hộ (Auto-Bid) tối đa đến mức này" />
                                </HBox>

                                <Button fx:id="btnPlaceBid" maxWidth="Infinity" onAction="#handlePlaceBid" prefHeight="50" style="-fx-background-color:#28a745; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:16; -fx-cursor: hand; -fx-background-radius: 8;" text="GỬI GIÁ ĐẤU" />
                                <Label fx:id="lblBidError" style="-fx-text-fill:red; -fx-font-size:12;" text="" wrapText="true" />
                            </VBox>

                            <VBox fx:id="panelSeller" managed="false" spacing="10" style="-fx-padding:15; -fx-background-color:#fff3cd; -fx-background-radius:10; -fx-border-color:#ffe69c; -fx-border-radius:10;" visible="false">
                                <Label style="-fx-font-weight:bold; -fx-text-fill:#856404; -fx-font-size: 14;" text="🛠 Bảng điều khiển Chủ Tài Sản" />
                                <Label style="-fx-font-size:12; -fx-text-fill:#856404; -fx-font-style: italic;" text="Chỉ khả dụng khi phiên đấu giá chưa bắt đầu." wrapText="true" />

                                <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                                    <Button maxWidth="Infinity" onAction="#handleCancelAuctionSeller" style="-fx-background-color:#dc3545; -fx-text-fill:white; -fx-font-weight:bold; -fx-cursor: hand;" text="Hủy phiên đấu giá" HBox.hgrow="ALWAYS" />
                                </HBox>
                            </VBox>

                            <VBox fx:id="panelAdmin" managed="false" spacing="10" style="-fx-padding:15; -fx-background-color:#343a40; -fx-background-radius:10; -fx-border-color:#23272b; -fx-border-radius:10;" visible="false">
                                <Label style="-fx-font-weight:bold; -fx-text-fill:white; -fx-font-size: 14;" text="🛡 Quản trị viên Kiểm duyệt" />

                                <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                                    <Button maxWidth="Infinity" onAction="#handleCancelAuctionSeller" style="-fx-background-color:#ffc107; -fx-text-fill:black; -fx-font-weight:bold; -fx-cursor: hand;" text="Hủy cuộc đấu giá" HBox.hgrow="ALWAYS" />
                                    <Button maxWidth="Infinity" onAction="#handleKickBidder" style="-fx-background-color:#dc3545; -fx-text-fill:white; -fx-font-weight:bold; -fx-cursor: hand;" text="Kick Người Dùng" HBox.hgrow="ALWAYS" />
                                </HBox>
                            </VBox>

                        </StackPane>
                        <Separator style="-fx-padding: 5 0;" />

                        <Label style="-fx-font-weight:bold; -fx-font-size: 14;" text="📊 Biểu đồ biến động giá" />
                        <LineChart fx:id="lineChart" createSymbols="true" prefHeight="170.0" style="-fx-padding: 0;">
                            <xAxis><NumberAxis label="Lượt" /></xAxis>
                            <yAxis><NumberAxis label="Giá (VND)" /></yAxis>
                        </LineChart>

                        <Label style="-fx-font-weight:bold; -fx-font-size: 14;" text="📜 Lịch sử đặt giá trực tiếp:" />
                        <ListView fx:id="lvBidHistory" minHeight="90.0" prefHeight="130.0" style="-fx-background-radius:5; -fx-font-family: monospace;" VBox.vgrow="ALWAYS" />

                        <Separator />

                        <VBox fx:id="vboxCheckoutSection" alignment="CENTER" spacing="10">
                            <Button fx:id="btnCheckout" managed="false" maxWidth="Infinity" onAction="#handleCheckout" prefHeight="50" style="-fx-background-color:#ff9f43; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:16; -fx-background-radius:8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2); -fx-cursor: hand;" text="💳 THANH TOÁN NGAY" visible="false" />
                            <Label fx:id="lblPostAuctionStatus" alignment="CENTER" managed="false" style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#e74c3c;" text="Giao dịch đã bị hủy!" visible="false" wrapText="true" />
                        </VBox>
                    </VBox>

                </HBox>
            </center>
        </BorderPane>
    </content>
</ScrollPane>
