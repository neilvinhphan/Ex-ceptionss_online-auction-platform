                                <MenuButton fx:id="menuUser" alignment="CENTER" maxWidth="-Infinity" mnemonicParsing="false" prefHeight="25.0" prefWidth="120.0" style="-fx-background-color: #28a745; -fx-background-radius: 50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="User">
                                    <items>
                                        <MenuItem mnemonicParsing="false" onAction="#handleUserUi" text="👤 Hồ sơ cá nhân" />
                                        <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="➜] Đăng xuất" />
                                    </items>
