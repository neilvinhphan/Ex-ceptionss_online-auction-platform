                                                                    <String fx:value="ART" />
                                                                    <String fx:value="ELECTRONICS" />
                                                                    <String fx:value="VEHICLE" />
                                                                </FXCollections>
                                                            </items>
                                                        </ComboBox>
                                                    </children>
                                                </VBox>
                                            </children>
