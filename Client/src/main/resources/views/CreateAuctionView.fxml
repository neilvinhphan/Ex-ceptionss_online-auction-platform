<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="768.0" prefWidth="1200.0" style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8; -fx-padding: 0; -fx-background-insets: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.CreateAuctionController">
  <content>
        <VBox minHeight="760.0" style="-fx-background-color: #F3F5F8;">
            <children>

                <BorderPane VBox.vgrow="ALWAYS">

                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                            </BorderPane.margin>
                            <fx:include source="UserMenuView.fxml" />
                        </VBox>
                    </top>

                    <left>
                        <VBox BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" left="40.0" right="20.0" />
                            </BorderPane.margin>
                            <fx:include source="UserSidebarView.fxml" />
                        </VBox>
                    </left>

                    <center>
                        <VBox spacing="25.0" BorderPane.alignment="CENTER">
                            <children>

                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                                    <children>
                                        <Label text="Tạo Cuộc Đấu Giá Mới">
                                            <font>
                                                <Font name="System Bold" size="26.0" />
                                            </font>
                                            <VBox.margin>
                                                <Insets bottom="10.0" />
                                            </VBox.margin>
                                        </Label>

                                        <HBox spacing="30.0">
                                            <children>
                                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #444;" text="Chọn sản phẩm chờ đấu giá *" />
                                                        <ComboBox fx:id="cbPendingItems" maxWidth="1.7976931348623157E308" promptText="-- Nhấn để chọn sản phẩm --" style="-fx-background-color: #FAFAFA; -fx-border-color: #28a745; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6; -fx-font-size: 14;" />
                                                    </children>
                                                </VBox>

                                                <VBox prefWidth="300.0" spacing="8.0">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #444;" text="Danh mục (Lọc / Tự động điền)" />
                                                        <ComboBox fx:id="cbCategory" maxWidth="1.7976931348623157E308" promptText="-- Tất cả danh mục --" style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6; -fx-font-size: 14;">
                                                            <items>
                                                                <FXCollections fx:factory="observableArrayList">
                                                                    <String fx:value="ART" />
                                                                    <String fx:value="ELECTRONICS" />
                                                                    <String fx:value="VEHICLE" />
                                                                </FXCollections>
                                                            </items>
                                                        </ComboBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #aaa;" text="Giá khởi điểm VNĐ (Tự động điền)" />
                                                <TextField fx:id="tfStartingPrice" editable="false" promptText="Giá sẽ hiển thị sau khi chọn sản phẩm..." style="-fx-background-color: #E9ECEF; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14; -fx-text-fill: #666;" />
                                            </children>
                                        </VBox>

                                        <HBox spacing="10.0">
                                            <children>
                                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #444;" text="Thời gian dự kiến MỞ phòng *" />
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                                            <DatePicker fx:id="dpStartDate" prefHeight="35.0" promptText="Chọn ngày" style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                                            <Spinner fx:id="startHourSpinner" prefHeight="35.0" prefWidth="70.0" style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                                            <Label style="-fx-text-fill: #555; -fx-font-size: 14;" text="giờ" />
                                                            <Spinner fx:id="startMinuteSpinner" prefHeight="35.0" prefWidth="70.0" style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                                            <Label style="-fx-text-fill: #555; -fx-font-size: 14;" text="phút" />
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <HBox spacing="10.0">
                                            <children>
                                                <VBox prefWidth="416.0" spacing="8.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #444;" text="Khoảng thời gian đấu giá*" />

                                                        <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="737.0" spacing="8.0">
                                                            <Spinner fx:id="durationHourSpinner" style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;" />

                                                            <Label style="-fx-text-fill: #555; -fx-font-size: 14;" text="giờ" />

                                                            <Spinner fx:id="durationMinuteSpinner" style="-fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;" />

                                                            <Label style="-fx-text-fill: #555; -fx-font-size: 14;" text="phút" />
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <VBox>
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #444;" text="Bước giá" />
                                                <TextField fx:id="tfBidIncrement" style="-fx-border-radius: 8;" styleClass="custom-text-field" />

                                                <Region style="-fx-border-color: #EEEEEE; -fx-border-width: 1 0 0 0;" />
                                            </children>
                                        </VBox>

                                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                            <children>
                                                <Button mnemonicParsing="false" style="-fx-background-color: #F1F3F5; -fx-text-fill: #333; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 25; -fx-cursor: hand; -fx-font-size: 15;" text="Hủy bỏ" />
                                                <Button mnemonicParsing="false" onAction="#handleSubmit" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 30; -fx-cursor: hand; -fx-font-size: 15; -fx-effect: dropshadow(gaussian, rgba(40,167,69,0.3), 10, 0, 0, 4);" text="LƯU &amp; TẠO ĐẤU GIÁ" />
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>
                            </children>
                            <BorderPane.margin>
                                <Insets bottom="40.0" right="40.0" />
                            </BorderPane.margin>
                        </VBox>
                    </center>
                    <bottom>

                         </bottom>
                </BorderPane>

            </children>
        </VBox>
    </content>
</ScrollPane>
