<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #1e1e1e;"
            stylesheets="@style.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controllers.AuctionApprovalController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">

            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="35.0"
                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                        text="⬅ Quay lại"/>
                <Label text="Kiểm duyệt phiên đấu giá" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">

                <VBox prefWidth="650.0" spacing="10.0" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Phiên đấu giá đang chờ duyệt" textFill="#deff9a">
                            <font>
                                <Font name="System Bold" size="16.0"/>
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="30.0"
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                                text="🔄 Làm mới"/>
                    </HBox>

                    <TableView fx:id="itemTable"
                               style="-fx-background-radius: 5; -fx-font-size: 14px;"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" maxWidth="80.0" minWidth="60.0"
                                         prefWidth="70.0" text="ID"/>
                            <TableColumn fx:id="colItemName" prefWidth="250.0" text="Tên sản phẩm"/>
                            <TableColumn fx:id="colType" prefWidth="130.0" text="Phân loại"/>
                            <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá khởi điểm"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox prefWidth="380.0" spacing="20.0"
                      style="-fx-background-color: #2d2d2d; -fx-padding: 25; -fx-background-radius: 10;">

                    <StackPane prefHeight="220.0"
                               style="-fx-background-color: #1a1a1a; -fx-background-radius: 10;">
                        <ImageView fx:id="itemImageView" fitHeight="200.0" fitWidth="320.0"
                                   pickOnBounds="true" preserveRatio="true"/>
                        <Label fx:id="lblNoImage" text="Chọn phiên bên trái để xem ảnh"
                               textFill="#888888">
                            <font>
                                <Font name="System Italic" size="14.0"/>
                            </font>
                        </Label>
                    </StackPane>

                    <VBox spacing="12.0">
                        <VBox spacing="5.0">
                            <Label text="Tên sản phẩm:" textFill="#aaaaaa"/>
                            <Label fx:id="lblName" text="..." textFill="WHITE" wrapText="true">
                                <font>
                                    <Font name="System Bold" size="20.0"/>
                                </font>
                            </Label>
                        </VBox>

                        <HBox spacing="20.0">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label text="Giá khởi điểm:" textFill="#aaaaaa"/>
                                <Label fx:id="lblPrice" text="..." textFill="#deff9a">
                                    <font>
                                        <Font name="System Bold" size="18.0"/>
                                    </font>
                                </Label>
                            </VBox>
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label text="Loại hàng:" textFill="#aaaaaa"/>
                                <Label fx:id="lblType" text="..." textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                        <Label text="Mô tả tóm tắt:" textFill="#aaaaaa"/>
                        <TextArea fx:id="txtDescription" editable="false" prefHeight="100.0"
                                  style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: #cccccc; -fx-font-size: 13px;"
                                  wrapText="true"/>
                    </VBox>

                    <VBox spacing="10.0">
                        <Button fx:id="btnApprove" disable="true" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" onAction="#handleApprove" prefHeight="50.0"
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 8; -fx-cursor: hand;"
                                text="✅ PHÊ DUYỆT PHÒNG"/>
                        <Button fx:id="btnReject" disable="true" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" onAction="#handleReject" prefHeight="40.0"
                                style="-fx-background-color: transparent; -fx-border-color: #dc3545; -fx-border-radius: 8; -fx-text-fill: #dc3545; -fx-font-weight: bold; -fx-cursor: hand;"
                                text="❌ TỪ CHỐI"/>
                    </VBox>

                </VBox>
            </HBox>
        </VBox>
    </children>
</AnchorPane>