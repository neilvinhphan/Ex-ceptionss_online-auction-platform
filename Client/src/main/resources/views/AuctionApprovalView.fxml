<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #1e1e1e;"
            stylesheets="@style.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controllers.AuctionApprovalController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">

            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="35.0"
                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                        text="⬅ Quay lại"/>
                <Label text="Kiểm duyệt phiên đấu giá" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">

                <VBox prefWidth="600.0" spacing="10.0" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Danh sách cần duyệt" textFill="#deff9a">
                            <font>
                                <Font name="System Bold" size="16.0"/>
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="30.0"
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                                text="🔄 Làm mới"/>
                    </HBox>

                    <TableView fx:id="itemTable"
                               style="-fx-background-radius: 5; -fx-font-size: 14px;"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="60.0" text="ID"/>
                            <TableColumn fx:id="colItemName" prefWidth="200.0" text="Tên sản phẩm"/>
                            <TableColumn fx:id="colType" prefWidth="120.0" text="Phân loại"/>
                            <TableColumn fx:id="colPrice" prefWidth="120.0" text="Giá khởi điểm"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox prefWidth="400.0" spacing="15.0"
                      style="-fx-background-color: #2d2d2d; -fx-padding: 20; -fx-background-radius: 10;">

                    <StackPane prefHeight="250.0"
                               style="-fx-background-color: #1a1a1a; -fx-background-radius: 10;">
                        <ImageView fx:id="itemImageView" fitHeight="240.0" fitWidth="350.0"
                                   pickOnBounds="true" preserveRatio="true"/>
                        <Label fx:id="lblNoImage" text="Chọn sản phẩm bên trái để xem"
                               textFill="#888888">
                            <font>
                                <Font name="System Italic" size="14.0"/>
                            </font>
                        </Label>
                    </StackPane>

                    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                        <Label text="Tên sản phẩm:" textFill="#aaaaaa"/>
                        <Label fx:id="lblName" text="..." textFill="WHITE" wrapText="true">
                            <font>
                                <Font name="System Bold" size="18.0"/>
                            </font>
                        </Label>

                        <HBox spacing="30.0">
                            <VBox spacing="5.0">
                                <Label text="Phân loại hàng:" textFill="#aaaaaa"/>
                                <Label fx:id="lblType" text="..." textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Giá khởi điểm:" textFill="#aaaaaa"/>
                                <Label fx:id="lblPrice" text="..." textFill="#deff9a">
                                    <font>
                                        <Font name="System Bold" size="16.0"/>
                                    </font>
                                </Label>
                            </VBox>
                        </HBox>

                        <Label text="Mô tả chi tiết:" textFill="#aaaaaa"/>
                        <TextArea fx:id="txtDescription" editable="false"
                                  style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: white; -fx-font-size: 14px; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"
                                  wrapText="true" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnApprove" disable="true" mnemonicParsing="false"
                                onAction="#handleApprove" prefHeight="45.0" prefWidth="160.0"
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 5; -fx-cursor: hand;"
                                text="✅ PHÊ DUYỆT"/>
                        <Button fx:id="btnReject" disable="true" mnemonicParsing="false"
                                onAction="#handleReject" prefHeight="45.0" prefWidth="160.0"
                                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 5; -fx-cursor: hand;"
                                text="❌ TỪ CHỐI"/>
                    </HBox>

                </VBox>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
