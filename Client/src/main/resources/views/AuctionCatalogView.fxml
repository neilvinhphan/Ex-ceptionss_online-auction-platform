<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="768.0" prefWidth="1200.0"
            style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8; -fx-padding: 0; -fx-background-insets: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"
            stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controllers.AuctionCatalogController">
   <content>
        <VBox>
            <children>
                <BorderPane style="-fx-background-color: #F8F9FA;" VBox.vgrow="ALWAYS">

                    <left>
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
                            <children>
                                <Label text="Lọc kết quả">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="20.0" />
                                    </VBox.margin>
                                </Label>
                                <Label text="Tài sản đấu giá">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </Label>
                                <VBox spacing="12.0">
                                    <children>
                                        <CheckBox fx:id="cbTypeAll" mnemonicParsing="false" selected="true" style="-fx-text-fill: #28a745; -fx-cursor: hand;" text="Tất cả " />
                                        <CheckBox fx:id="cbTypeElectronics" mnemonicParsing="false" style="-fx-cursor: hand;" text="Đồ điện" />
                                        <CheckBox fx:id="cbTypeVehicle" mnemonicParsing="false" style="-fx-cursor: hand;" text="Phương tiện" />
                                        <CheckBox fx:id="cbTypeArt" mnemonicParsing="false" style="-fx-cursor: hand;" text="Tác phẩm nghệ thuật" />
                                    </children>
                                    <VBox.margin><Insets bottom="25.0" /></VBox.margin>
                                </VBox>
                                <Label text="Trạng thái tài sản">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </Label>
                                <VBox spacing="12.0">
                                    <children>
                                        <RadioButton fx:id="rbStatusAll" mnemonicParsing="false" onAction="#handleFilter" selected="true" style="-fx-text-fill: #28a745; -fx-cursor: hand;" text="Tất cả" />
                                        <RadioButton fx:id="rbStatusOpen" mnemonicParsing="false" onAction="#handleFilter" style="-fx-cursor: hand;" text="Sắp diễn ra" />
                                        <RadioButton fx:id="rbStatusRunning" mnemonicParsing="false" onAction="#handleFilter" style="-fx-cursor: hand;" text="Đang diễn ra" />
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="25.0" />
                                    </VBox.margin>
                                </VBox>
                                <Label text="Giá khởi điểm (đ)">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets bottom="10.0" />
                                    </VBox.margin>
                                </Label>
                                <VBox spacing="12.0">
                                    <children>
                                        <RadioButton fx:id="rbPriceAll" mnemonicParsing="false" selected="true" style="-fx-text-fill: #28a745; -fx-cursor: hand;" text="Tất cả" />
                                        <RadioButton fx:id="rbPrice1" mnemonicParsing="false" style="-fx-cursor: hand;" text="Dưới 50.000.000" />
                                        <RadioButton fx:id="rbPrice2" mnemonicParsing="false" style="-fx-cursor: hand;" text="50.000.000 - 200.000.000" />
                                        <RadioButton fx:id="rbPrice3" mnemonicParsing="false" style="-fx-cursor: hand;" text="200.000.001 - 500.000.000" />
                                        <RadioButton fx:id="rbPrice4" mnemonicParsing="false" style="-fx-cursor: hand;" text="500.000.001 - 2.000.000.000" />
                                        <RadioButton fx:id="rbPrice5" mnemonicParsing="false" style="-fx-cursor: hand;" text="Trên 2.000.000.000" />
                                    </children>
                                    <VBox.margin><Insets bottom="25.0" /></VBox.margin>
                                </VBox>
                                <Region VBox.vgrow="ALWAYS" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleFilter" style="-fx-font-weight: bold; -fx-background-color: #28a745; -fx-text-fill: white; -fx-padding: 12 15; -fx-font-size: 15; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" text="LỌC TÀI SẢN" />
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="25.0" right="25.0" top="30.0" />
                            </padding>
                            <BorderPane.margin>
                                <Insets bottom="30.0" left="40.0" right="20.0" />
                            </BorderPane.margin>
                        </VBox>
                    </left>

                    <center>
                        <VBox BorderPane.alignment="CENTER">
                            <children>
                                <HBox fx:id="upgradeBanner" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                                    <VBox.margin>
                                        <Insets bottom="30.0" />
                                    </VBox.margin>
                                    <children>
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label text="Trở thành Người Bán (Seller) ngay hôm nay!" textFill="#333333">
                                                    <font>
                                                        <Font name="System Bold" size="24.0" />
                                                    </font>
                                                </Label>
                                                <Label text="Mở khóa tính năng tạo phòng đấu giá, đăng bán tài sản và tiếp cận hàng ngàn người mua." textFill="#666666">
                                                    <font>
                                                        <Font size="15.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleUpgrade" style="-fx-background-color: #ffc107; -fx-text-fill: #333333; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 25; -fx-cursor: hand; -fx-font-size: 16; -fx-effect: dropshadow(gaussian, rgba(255,193,7,0.4), 10, 0, 0, 4);" text="🚀 Nâng cấp Seller" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Danh sách phòng đấu giá">
                                            <font>
                                                <Font name="System Bold" size="24.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                    </children>
                                    <VBox.margin>
                                        <Insets bottom="30.0" />
                                    </VBox.margin>
                                </HBox>

                                <FlowPane fx:id="auctionFlowPane" hgap="25.0" vgap="25.0" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets bottom="20.0" right="20.0" />
                                    </padding>
                                </FlowPane>

                            </children>
                            <padding>
                                <Insets bottom="20.0" right="40.0" />
                            </padding>
                        </VBox>
                    </center>

                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                            </BorderPane.margin>
                            <fx:include source="UserMenuView.fxml" />
                        </VBox>
                    </top>

                    <bottom>
                      </bottom>
                </BorderPane>
            </children>
        </VBox>
    </content>
</ScrollPane>
