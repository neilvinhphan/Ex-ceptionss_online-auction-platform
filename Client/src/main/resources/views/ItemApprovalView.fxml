<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="768.0" prefWidth="1200.0"
            style="-fx-background-color: #F3F5F8; -fx-background: #F3F5F8; -fx-padding: 0; -fx-background-insets: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;"
            stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.client.controllers.ItemApprovalController">
    <content>
        <VBox minHeight="760.0" style="-fx-background-color: #F3F5F8;">
            <children>

                <BorderPane VBox.vgrow="ALWAYS">

                    <top>
                        <VBox BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets bottom="20.0" left="75.0" right="75.0" top="35.0" />
                            </BorderPane.margin>
                            <fx:include source="AdminMenuView.fxml" />
                        </VBox>
                    </top>

                    <left>
                        <VBox BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" left="40.0" right="20.0" />
                            </BorderPane.margin>
                            <fx:include source="AdminSideBarView.fxml" />
                        </VBox>
                    </left>

                    <center>
                        <VBox spacing="20.0" BorderPane.alignment="TOP_LEFT">
                            <BorderPane.margin>
                                <Insets bottom="40.0" right="40.0" />
                            </BorderPane.margin>
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox>
                                            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="Kiểm Duyệt Sản Phẩm Chờ">
                                                <font>
                                                    <Font size="24.0" />
                                                </font>
                                            </Label>
                                            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" text="Xem xét và quyết định cho phép tài sản được lên sàn đấu giá hay không." />
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="20.0" VBox.vgrow="ALWAYS">

                                    <VBox prefWidth="600.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT">
                                            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="Danh sách cần duyệt">
                                                <font>
                                                    <Font size="18.0" />
                                                </font>
                                            </Label>
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="35.0" style="-fx-background-color: #ecfdf5; -fx-text-fill: #059669; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15;" text="🔄 Làm mới" />
                                        </HBox>

                                        <TableView fx:id="itemTable" style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                                <TableColumn fx:id="colItemName" prefWidth="200.0" text="Tên sản phẩm" />
                                                <TableColumn fx:id="colType" prefWidth="120.0" text="Phân loại" />
                                                <TableColumn fx:id="colPrice" prefWidth="120.0" text="Giá khởi điểm" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </VBox>

                                    <VBox prefWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">

                                        <StackPane prefHeight="250.0" style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
                                            <ImageView fx:id="itemImageView" fitHeight="240.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true" />
                                            <Label fx:id="lblNoImage" style="-fx-text-fill: #94a3b8; -fx-font-style: italic;" text="Chọn sản phẩm bên trái để xem">
                                                <font>
                                                    <Font size="14.0" />
                                                </font>
                                            </Label>
                                        </StackPane>

                                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                                            <VBox spacing="2.0">
                                                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" text="Tên sản phẩm:" />
                                                <Label fx:id="lblName" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="..." wrapText="true">
                                                    <font>
                                                        <Font size="20.0" />
                                                    </font>
                                                </Label>
                                            </VBox>

                                            <HBox spacing="40.0">
                                                <VBox spacing="2.0">
                                                    <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" text="Phân loại hàng:" />
                                                    <Label fx:id="lblType" style="-fx-text-fill: #34495e; -fx-font-weight: bold;" text="...">
                                                        <font>
                                                            <Font size="16.0" />
                                                        </font>
                                                    </Label>
                                                </VBox>
                                                <VBox spacing="2.0">
                                                    <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" text="Giá khởi điểm:" />
                                                    <Label fx:id="lblPrice" style="-fx-text-fill: #16a34a; -fx-font-weight: bold;" text="...">
                                                        <font>
                                                            <Font size="18.0" />
                                                        </font>
                                                    </Label>
                                                </VBox>
                                            </HBox>

                                            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                                                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" text="Mô tả chi tiết:" />
                                                <TextArea fx:id="txtDescription" editable="false" style="-fx-control-inner-background: #f8fafc; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" wrapText="true" VBox.vgrow="ALWAYS" />
                                            </VBox>
                                        </VBox>

                                        <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10 0 0 0; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
                                            <Button fx:id="btnApprove" disable="true" mnemonicParsing="false" onAction="#handleApprove" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 8; -fx-cursor: hand;" text="✅ PHÊ DUYỆT" />
                                            <Button fx:id="btnReject" disable="true" mnemonicParsing="false" onAction="#handleReject" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 8; -fx-cursor: hand;" text="❌ TỪ CHỐI" />
                                        </HBox>

                                    </VBox>
                                </HBox>

                            </children>
                        </VBox>
                    </center>
                </BorderPane>

            </children>
        </VBox>
    </content>
</ScrollPane>
