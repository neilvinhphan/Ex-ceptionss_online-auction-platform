<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER" spacing="20.0" style="-fx-background-radius: 40; -fx-background-color: white; -fx-padding: 10 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.UserMenuController">
    <children>
        <Button mnemonicParsing="false" onAction="#handleMain" style="-fx-background-radius: 30; -fx-font-weight: bold; -fx-background-color: transparent; -fx-font-size: 16; -fx-text-fill: #28a745; -fx-cursor: hand;" text="Trang chủ" />
        <Button mnemonicParsing="false" onAction="#handleMenuItem" prefHeight="25.0" style="-fx-background-color: #28a745; -fx-background-radius: 50; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold;" text="Danh sách phòng" />

        <Button fx:id="btnBackToAdmin" managed="false" mnemonicParsing="false" onAction="#handleBackToAdmin" style="-fx-background-color: #e63946; -fx-background-radius: 50; -fx-cursor: hand; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 5 15;" text="⬅ Quay về Dashboard Admin" visible="false" />

        <Region HBox.hgrow="ALWAYS" />

        <VBox alignment="CENTER" spacing="3.0">
            <children>
                <MenuButton fx:id="menuUser" alignment="CENTER" maxWidth="Infinity" mnemonicParsing="false" prefHeight="25.0" prefWidth="120.0" style="-fx-background-color: #28a745; -fx-background-radius: 50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" styleClass="user-menu-btn" text="User">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#handleUserUi" styleClass="menu-item" text="Hồ sơ cá nhân" />
                        <MenuItem mnemonicParsing="false" onAction="#handleLogout" styleClass="menu-item" text="Đăng xuất" />
                    </items>
                </MenuButton>
                <Label fx:id="roleLabel" style="-fx-text-fill: #666666; -fx-font-size: 11; -fx-font-style: italic;" text="Vai trò: Đang tải..." />
            </children>
        </VBox>
    </children>
</HBox>