<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.user.UserMenuController">
    <padding>
        <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
    </padding>
    <children>

        <VBox alignment="CENTER_LEFT" spacing="2.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 24; -fx-text-fill: #2c3e50;" text="AuctionPro" />
                <Label fx:id="roleLabel" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: #28a745; -fx-background-color: #d4edda; -fx-padding: 2 6; -fx-background-radius: 4;" text="BIDDER" />
            </children>
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="15.0">
            <children>

                <Button mnemonicParsing="false" onAction="#handleMenuItem" style="-fx-background-color: transparent; -fx-text-fill: #28a745; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14;" text="🏛 Danh sách phòng" />

                <Button fx:id="btnBackToAdmin" managed="false" mnemonicParsing="false" onAction="#handleBackToAdmin" style="-fx-background-color: #f8d7da; -fx-text-fill: #721c24; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 15; -fx-cursor: hand; -fx-font-size: 13;" text="⬅ Quay về Admin" visible="false" />

                <Region style="-fx-border-color: #e2e8f0; -fx-border-width: 0 1 0 0;" />

                <MenuButton fx:id="menuUser" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14;" text="👤 Tài khoản">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#handleUserUi" text="Hồ sơ cá nhân" />
                        <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Đăng xuất" />
                    </items>
                </MenuButton>

            </children>
        </HBox>

    </children>
</HBox>
