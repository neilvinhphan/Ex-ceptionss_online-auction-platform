<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.AdminMenuController">
    <padding>
        <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
    </padding>
    <children>

        <VBox alignment="CENTER_LEFT" spacing="2.0">
            <Label style="-fx-font-weight: bold; -fx-font-size: 24; -fx-text-fill: #2c3e50;" text="AuctionPro" />
            <Label style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: #e74c3c; -fx-background-color: #fadbd8; -fx-padding: 2 6; -fx-background-radius: 4;" text="ADMIN PANEL" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="15.0">

            <Button mnemonicParsing="false" onAction="#handleSwitchToUserUI" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14;" text="👁Xem trang khách" />

            <Region style="-fx-border-color: #e2e8f0; -fx-border-width: 0 1 0 0;" />

            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14;" text="👑 Xin chào, Admin" />

            <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 14;" text="🚪 Đăng xuất" />

        </HBox>

    </children>
</HBox>
