<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" prefWidth="280.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.client.controllers.AdminSidebarController">
    <children>
        <!-- Nút Tổng quan (Đang Active) -->
        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDashboard" style="-fx-font-weight: bold; -fx-background-color: #e0e7ff; -fx-text-fill: #4f46e5; -fx-font-size: 15; -fx-padding: 15 20; -fx-cursor: hand; -fx-background-radius: 10;" text="📊 Tổng quan hệ thống" />

        <!-- Quản lý tài sản chờ duyệt -->
        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleApproveItem" style="-fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15; -fx-padding: 15 20; -fx-cursor: hand;" text="📋 Duyệt tài sản" />

        <!-- Quản lý người dùng -->
        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleManageUsers" style="-fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15; -fx-padding: 15 20; -fx-cursor: hand;" text="👥 Quản lý người dùng" />

        <!-- Quản lý phiên đấu giá -->
        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleManageAuctions" style="-fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15; -fx-padding: 15 20; -fx-cursor: hand;" text="⚖️ Quản lý phiên đấu giá" />

        <!-- Đường kẻ ngang phân cách -->
        <VBox style="-fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 10 0 0 0;">
            <VBox.margin>
                <Insets bottom="5.0" top="10.0" />
            </VBox.margin>
        </VBox>

        <!-- Nút Cảnh báo / Dừng khẩn cấp -->
        <Button alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSystemAlerts" style="-fx-font-weight: bold; -fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-padding: 15 20; -fx-font-size: 15; -fx-background-radius: 10; -fx-cursor: hand;" text="🚨 Dừng khẩn cấp phiên" />
    </children>
    <padding>
        <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
    </padding>
</VBox>